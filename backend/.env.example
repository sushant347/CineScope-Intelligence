DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-api.onrender.com

# Neon PostgreSQL
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# Optional override; defaults to ../ml/models
ML_MODEL_DIR=
