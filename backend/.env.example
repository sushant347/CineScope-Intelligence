DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=False
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1

# Neon PostgreSQL
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEXES=https://.*\.vercel\.app
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://*.vercel.app

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# Optional override; defaults to ../ml/models
ML_MODEL_DIR=

# Optional hosted BERT fallback (used when local BERT artifacts are unavailable)
HF_BERT_MODEL_ID=distilbert-base-uncased-finetuned-sst-2-english
HF_API_TOKEN=
HF_BERT_TIMEOUT_SECONDS=8
HF_BERT_RETRIES=1
HF_BERT_WAIT_FOR_MODEL=False

# Keep disabled in production unless you explicitly want first-request SVM bootstrapping.
ENABLE_SVM_RUNTIME_BOOTSTRAP=False
